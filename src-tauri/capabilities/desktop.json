{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "desktop-capability",
	"description": "Desktop-only capability (opener). Filesystem access is scoped to the preferences file like the shared capability — broad fs:default is not needed, and a WebView compromise should not inherit full-disk read/write.",
	"windows": [
		"main"
	],
	"platforms": [
		"linux",
		"macOS",
		"windows"
	],
	"permissions": [
		"opener:default",
		{
			"identifier": "fs:allow-app-read",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		},
		{
			"identifier": "fs:allow-app-write",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		},
		{
			"identifier": "fs:allow-exists",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		}
	]
}
