# Copy this to a private location (outside the repo) and point
# OPEN_GRIND_KEYSTORE_PROPERTIES at it when building a signed release:
#
#   OPEN_GRIND_KEYSTORE_PROPERTIES=/path/to/keystore.properties \
#     nix run .#build-android
#
# The Nix build copies it to src-tauri/gen/android/keystore.properties for
# the duration of the build and removes it on exit. Never commit your real
# JKS or this file with real values.

# storeFile may use `~/` for your home directory.
# keyAlias must match whatever you passed to `keytool -alias …` when you
# created the JKS — BUILDING.md's example uses `open-grind`.
storeFile=~/.config/open-grind/release.jks
keyAlias=open-grind
password=change-me
